@model mvc2025TermProject.Models.RecipeCardViewModel

<a asp-controller="Browse" asp-action="Recipe" asp-route-id="@Model.ID" class="text-dark">
    <div class="card recipe-card h-100 border-0 bg-transparent shadow-0">
        @{
            var mainImage = Model.Images?.FirstOrDefault(i => i.IsApproved == true && i.IsMainImage == true);
        }

        @if (mainImage != null)
        {
            <img src="@mainImage.FilePath" class="card-img-top w-100 rounded-lg h-250" alt="@Model.Name" style="object-fit: cover;">
        }
        else
        {
            <div class="card-img-top bg-light rounded-lg h-250"></div>
        }

        <div class="bg-transparent p-3">
            <h6 class="bg-transparent text-center mb-0">@Model.Name</h6>
        </div>
    </div>
</a>

<style>
    .recipe-card:hover {
        box-shadow: none !important;
    }
</style>