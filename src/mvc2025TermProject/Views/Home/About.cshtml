
@{
    ViewData["Title"] = "About Us";
}

<section class="p-0">

    <div class="container">
        <section class="my-3 my-md-4">
            <h5 class="fs-2 py-3 mb-0">About Campus Bites</h5>

            <div class="about-detail">

                <hr class="my-0 my-md-3" />
                <p class="lead fs-5 mt-3 text-justify">
                    <span class="fw-bold">Campus Bites</span> is a student-built recipe website designed to make cooking simple, 
                    affordable, and stress-free for college and university students.
                </p>

                <img src="~/img/banner-about-ingredients.jpg" class="img-fluid w-100" alt="Ingredients">
               
                <p class="fs-5 mt-3 text-justify">
                    We understand that between classes, assignments, and tight budgets, preparing meals can feel like a challenge, 
                    that’s why Campus Bites focuses on <span class="fw-bold">easy</span>, <span class="fw-bold">budget-friendly recipes</span> 
                    using minimal ingredients and everyday kitchen tools. Whether you’re living in a dorm with only a microwave, sharing 
                    a student apartment, or learning to cook for the first time, Campus Bites is here to help you make tasty, healthy meals without breaking the bank.
                </p>

                <p class="fs-5 mt-3 text-justify">
                    The platform allows students to <span class="fw-bold">browse recipes</span>, <span class="fw-bold">create their own dishes</span>, and 
                    <span class="fw-bold">share them with the community</span>, encouraging collaboration and creativity in the kitchen. Each recipe includes step-by-step 
                    instructions, estimated prep times, and clear ingredient details, so you can focus on what matters, enjoying your meal.
                </p>
            </div>
        </section>

        <section class="my-3 my-md-5">
            <h5 class="fs-2 py-3 mb-0">Our Story</h5>
            <div class="our-story">
                <hr class="my-0 my-md-3" />
                
                    <div class="mt-3">
                        <p class="fs-5 text-justify">
                            Campus Bites began as a class project at the <span class="fw-bold">New Brunswick Community College (NBCC)</span>,
                            built by IT Software Development students <span class="fw-bold">Luc Langis</span> and <span class="fw-bold">Brian Cabello</span>.
                            What started as a coding Term Project quickly became a vision for a community-driven platform where students could share their favorite recipes and meal ideas.
                        </p>

                        <p class="fs-5 mt-3 fst-italic text-center text-secondary">
                            "Easy Meals for Student Life"
                        </p>
                    </div>

                <div class="row mt-5">

                    <div class="col-md-6 d-flex align-items-center justify-content-center">
                        <div class="card h-100 w-75 border-0 shadow-sm">
                            <div class="card-img-top bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center" style="height: 200px">
                                <span class="text-secondary fw-semibold">Thumbnail</span>
                            </div>
                            <div class="card-body text-center">
                                <h5 class="card-title fw-bold mb-2">Luc Langis</h5>
                                <p class="card-text text-secondary">
                                    IT Software Development Sr A
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 d-flex align-items-center justify-content-center">
                        <div class="card h-100 w-75 border-0 shadow-sm">
                            <div class="card-img-top bg-secondary bg-opacity-25 d-flex align-items-center justify-content-center" style="height: 200px">
                                <span class="text-secondary fw-semibold">Thumbnail</span>
                            </div>
                            <div class="card-body text-center">
                                <h5 class="card-title fw-bold mb-2">Brian Cabello</h5>
                                <p class="card-text text-secondary">
                                    IT Software Development Sr A
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <section class="bg-cta my-5 py-5">
        <div class="container text-center py-4 py-md-5">
            <h2 class="fs-1 fw-bold text-dark mb-3">Let’s Stir Up Something New</h2>
            <p class="text-secondary mb-4">
                Have a recipe idea or suggestion that could make student life easier?
                <br />
                We’re always looking for creative new dishes, and we’d love to hear from you!
            </p>
            <a asp-controller="Contact" asp-action="Index" class="btn btn-lg text-light border-0 btn-cb-primary">
                Contact Our Team
            </a>
        </div>
    </section>

    @if (Model.OurPicks != null && Model.OurPicks.Count > 0)
    {
        <div class="container">
            <section class="my-3 my-md-4">
                <h3 class="fs-2 text-center mb-4">Our Picks</h3>
                <p class=" fs-5 text-center mb-5">
                    Here are some of our favorite recipes that perfectly capture what Campus Bites is all about — simple, tasty, and budget-friendly.
                </p>

                <div class="row g-3">
                    @foreach (var recipe in Model.OurPicks)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <partial name="Partials/_ChefsPickPartial" model="recipe" />
                        </div>
                    }
                </div>
            </section>
        </div>
    }

</section>
