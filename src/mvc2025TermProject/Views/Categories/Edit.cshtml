@model mvc2025TermProject.Models.CategoryDetailViewModel

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container my-3 my-md-4">
    <div class="position-relative">
        <div class="auth-accent rounded-top"></div>

        <div class="bg-white border shadow-sm overflow-hidden">

            <div class="d-flex flex-wrap align-items-center justify-content-between p-3 p-md-4 border-bottom">
                <h3 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h3>
                <a asp-action="Index" class="btn btn-light border shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Categories
                </a>
            </div>

            <div class="p-3 p-md-4">

                @if (Model.Status == "Pending Approval")
                {
                    <!-- Pending Approval -->
                    <div class="alert alert-secondary d-flex align-items-center" role="alert">
                        <i class="bi bi-hourglass-split me-2"></i>
                        <div>
                            This category is <strong>Pending Approval</strong>. Your edits will remain pending
                            until an admin reviews them.
                        </div>
                    </div>
                }
                else if (Model.Status == "Approved")
                {
                    <!-- Approved -->
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        <div>
                            This category is <strong>Approved</strong>. Any changes you save will be submitted
                            for review and will not appear until approved.
                        </div>
                    </div>
                }
                else if (Model.Status == "Pending Update")
                {
                    <!-- Pending Update -->
                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="bi bi-clock-history me-2"></i>
                        <div>
                            This category has a <strong>Pending Update</strong>. New edits will queue until admin approval.
                        </div>
                    </div>
                }

                <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="ID" />


                    @{
                        var formModel = new CategoryFormFieldsViewModel
                        {
                            Name = Model.Name,
                            Description = Model.Description
                        };
                    }

                    <partial name="_CategoryFormFields" model="formModel" />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-cb-primary shadow-sm">
                            <i class="bi bi-save2 me-1"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
