@model PaginatedList<mvc2025TermProject.Models.CategoryListViewModel>

@{
    ViewData["Title"] = "Categories";
}

<div class="container my-3 my-md-4">
    <div class="position-relative">
        <div class="auth-accent rounded-top"></div>

        <div class="bg-white border rounded-bottom shadow-sm overflow-hidden">

            <div class="d-flex flex-column px-4 py-3 border-bottom">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h3>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-action="Create" class="btn btn-outline-cb-primary shadow-sm">
                            <i class="bi bi-plus-circle me-1"></i> Add Category
                        </a>
                    }
                </div>

                <!-- Search -->
                <form asp-action="Index" method="get">
                    <div class="d-flex gap-2">
                        <div class="flex-grow-1">
                            <div class="input-group">
                                <input type="text" name="filterCriteria" value="@ViewData["SearchFilterCriteria"]"
                                       class="form-control" placeholder="Search categories by name, description, or status..." 
                                />

                                <button type="submit" class="btn btn-cb-primary">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>

                        <a asp-action="Index" class="btn btn-light border text-dark">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                        </a>

                    </div>
                </form>

                @if ((bool)ViewData["HasSearch"]!)
                {
                    <div class="mt-2">
                        <small class="text-muted">
                            Found @ViewData["TotalMatches"] match(es) for "@ViewData["SearchFilterCriteria"]"
                        </small>
                    </div>
                }
            </div>

            <div class="table-responsive px-4 pb-3">
                <table class="table table-borderless table-hover align-middle mb-0">
                    <thead class="text-nowrap">
                        <tr>
                            <th>
                                <a asp-action="Index"
                                   asp-route-sortOrder="@ViewData["NameSortParam"]"
                                   asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
                                   class="text-decoration-none text-dark"
                                >
                                    @Html.DisplayNameFor(model => model.First().Name)

                                    @if ((string)ViewData["NameSortParam"]! == "name_desc")
                                    {
                                        <i class="bi bi-sort-down text-color-eb"></i>
                                    }
                                    else if ((string)ViewData["NameSortParam"]! == null)
                                    {
                                        <i class="bi bi-sort-up text-color-eb"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-color-eb"></i>
                                    }
                                </a>
                            </th>
                            <th>@Html.DisplayNameFor(model => model.First().Description)</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-sortOrder="@ViewData["StatusSortParam"]"
                                   asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
                                   class="text-decoration-none text-dark"
                                >
                                    @Html.DisplayNameFor(model => model.First().Status)

                                    @if ((string)ViewData["StatusSortParam"]! == "status_desc")
                                    {
                                        <i class="bi bi-sort-down text-color-eb"></i>
                                    }
                                    else if ((string)ViewData["StatusSortParam"]! == "status")
                                    {
                                        <i class="bi bi-sort-up text-color-eb"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-color-eb"></i>
                                    }
                                </a>
                            </th>
                            <th>@Html.DisplayNameFor(model => model.First().RecipeCount)</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-sortOrder="@ViewData["DateSortParam"]"
                                   asp-route-filterCriteria="@ViewData["SearchFilterCriteria"]"
                                   class="text-decoration-none text-dark"
                                >
                                    @Html.DisplayNameFor(model => model.First().CreatedDate)

                                    @if ((string)ViewData["DateSortParam"]! == "date_desc")
                                    {
                                        <i class="bi bi-sort-down text-color-eb"></i>
                                    }
                                    else if ((string)ViewData["DateSortParam"]! == "date")
                                    {
                                        <i class="bi bi-sort-up text-color-eb"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-filter text-color-eb"></i>
                                    }
                                </a>
                            </th>
                            <th>@Html.DisplayNameFor(model => model.First().UnderReview)</th>

                        </tr>
                    </thead>
                    <tbody>
                        @if (Model is null || !Model.Any())
                        {
                            <tr class="border-top">
                                <td colspan="6" class="text-center py-4 text-muted">No categories found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr class="border-top">
                                    <td class="fw-semibold">
                                        <a asp-action="Details" asp-route-id="@item.ID" class="text-decoration-none text-color-eb">
                                            @Html.DisplayFor(modelItem => item.Name)
                                        </a>
                                    </td>
                                    <td class="text-wrap">@Html.DisplayFor(modelItem => item.Description)</td>
                                    <td class="text-nowrap">
                                        @if (item.Status == "Approved")
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (item.Status == "Pending Approval")
                                        {
                                            <span class="badge bg-secondary">Pending Approval</span>
                                        }
                                        else if (item.Status == "Pending Update")
                                        {
                                            <span class="badge bg-warning text-dark">Pending Update</span>
                                        }
                                        else if (item.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                    </td>
                                    <td class="text-nowrap text-center">@Html.DisplayFor(modelItem => item.RecipeCount)</td>
                                    <td class="text-nowrap">@Html.DisplayFor(modelItem => item.CreatedDate)</td>
                                    <td class="text-nowrap text-center">
                                        @if (item.UnderReview == true)
                                        {
                                            <span class="badge bg-warning text-dark">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">No</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <partial name="_PaginationPartial" model="Model" />

        </div>
    </div>
</div>