@model mvc2025TermProject.Models.RecipeDetailsViewModel

@{
    ViewData["Title"] = "Print";
}

<!-- Recipe Details -->
<section class="py-3 py-md-4">
    <h1 class="fw-bold mb-2 text-dark text-center">@Model.Name</h1>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">

                <div class="card-img-top position-relative bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height: 300px;">
                    @if (Model.Images?.Any(img => img.IsApproved == true) == true)
                    {
                        var approvedImages = Model.Images.Where(img => img.IsApproved == true).ToList();
                        var mainImage = approvedImages.FirstOrDefault(img => img.IsMainImage == true) ?? approvedImages.First();

                        <!-- Main Image -->
                        <img src="@mainImage.FilePath" class="img-fluid h-100 w-100" style="object-fit: contain;" alt="@mainImage.AltText" title="@mainImage.Description">
                    }
                    else
                    {
                        <div class="text-center">
                            <i class="bi bi-image text-secondary opacity-50 display-1 mb-3"></i>
                            <span class="text-secondary fw-semibold d-block fs-5">Image Not Available</span>
                        </div>
                    }
                </div>

                <div class="card-body p-4">
                    <div class="px-3 px-md-4 pb-3 pb-md-4">
                        <div class="d-flex flex-wrap justify-content-center text-center py-3 px-4 small fw-semibold text-muted text-uppercase">
                            <div class="mx-3">
                                <div>@Html.DisplayNameFor(m => m.PreparationTime)</div>
                                <div class="text-dark">@Html.DisplayFor(m => m.PreparationTime)</div>
                            </div>
                            @if (Model.CookTime != "N/A" && Model.CookTime != "0 min(s)")
                            {
                                <div class="mx-3">
                                    <div>@Html.DisplayNameFor(m => m.CookTime)</div>
                                    <div class="text-dark">@Html.DisplayFor(m => m.CookTime)</div>
                                </div>
                            }
                            <div class="mx-3">
                                <div>@Html.DisplayNameFor(m => m.TotalTime)</div>
                                <div class="text-dark">@Html.DisplayFor(m => m.TotalTime)</div>
                            </div>
                            @if (Model.TemperatureFahrenheit != "N/A")
                            {
                                <div class="mx-3">
                                    <div>@Html.DisplayNameFor(m => m.TemperatureFahrenheit)</div>
                                    <div class="text-dark">@Html.DisplayFor(m => m.TemperatureFahrenheit)</div>
                                </div>
                            }
                            <div class="mx-3">
                                <div>@Html.DisplayNameFor(m => m.Servings)</div>
                                <div class="text-dark">@Html.DisplayFor(m => m.Servings)</div>
                            </div>
                        </div>
                    </div>

                    <!-- Ingredients & Instructions Columns -->
                    <div class="row g-4">
                        <!-- Ingredients Column -->
                        <div class="col-lg-6">
                            <h5 class="fw-bold pb-2 mb-3">Ingredients</h5>
                            @if (Model.Ingredients == null || !Model.Ingredients.Any())
                            {
                                <p class="text-muted">No ingredients listed.</p>
                            }
                            else
                            {
                                <div class="ingredients-list">
                                    @foreach (var ingredient in Model.Ingredients)
                                    {
                                        <div class="d-flex align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="form-check">
                                                    <input class="form-check-input ingredient-checkbox" type="checkbox" id="ingredient-@ingredient.IngredientId">
                                                    <label class="form-check-label fw-semibold d-inline ingredient-label" for="ingredient-@ingredient.IngredientId">
                                                        <span>@ingredient.Quantity @ingredient.Unit</span>
                                                        <span>@ingredient.IngredientName</span>
                                                        @if (!string.IsNullOrEmpty(ingredient.Notes))
                                                        {
                                                            <span>@ingredient.Notes</span>
                                                        }
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Special Equipment -->
                            @if (!string.IsNullOrEmpty(Model.SpecialEquipment))
                            {
                                <div class="mt-4">
                                    <h6 class="fw-bold pb-2 mb-3">Special Equipment</h6>
                                    <p class="mb-0" style="white-space: pre-wrap;">@Model.SpecialEquipment</p>
                                </div>
                            }

                            <!-- Nutrition Information -->
                            @if (!string.IsNullOrEmpty(Model.NutritionInfo))
                            {
                                <div class="mt-4">
                                    <h6 class="fw-bold pb-2 mb-3">Nutrition Information</h6>
                                    <p class="mb-0" style="white-space: pre-wrap;">@Model.NutritionInfo</p>
                                </div>
                            }
                        </div>

                        <!-- Instructions Column -->
                        <div class="col-lg-6">
                            <h5 class="fw-bold pb-2 mb-3">Instructions</h5>
                            <div style="white-space: pre-wrap;">@Html.DisplayFor(m => m.Instructions)</div>

                            @if (!string.IsNullOrWhiteSpace(Model.Tips))
                            {
                                <div class="mt-4">
                                    <h6 class="fw-bold pb-2 mb-3">Tips</h6>
                                    <p style="white-space: pre-wrap;" class="mb-0">@Html.DisplayFor(m => m.Tips)</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    window.onload = function() {
        window.print();
    };
</script>

<style>
    header, footer, .no-print {
        display: none !important;
    }

    body {
        padding: 30px;
    }
</style>