@model List<mvc2025TermProject.Models.CategoryCardViewModel>

<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        @foreach (var category in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <a asp-controller="Browse" asp-action="Category" asp-route-id="@category.ID"
                   class="card category-card h-100 border-0 shadow-sm text-dark">
                    <div class="card-body text-center p-4">
                        <div class="category-icon mb-3">
                            <i class="bi bi-tag-fill display-6 text-color-eb"></i>
                        </div>

                        <h5 class="card-title fw-bold mb-2">@category.Name</h5>
                        <div class="small">
                            @if (@category.Status == "Approved")
                            {
                                @* <span class="badge bg-success">Approved</span> *@
                            }
                            else if (@category.Status == "Pending Approval")
                            {
                                <span class="badge bg-secondary">Pending Approval</span>
                            }
                            else if (@category.Status == "Pending Update")
                            {
                                <span class="badge bg-warning text-dark">Pending Update</span>
                            }
                            else if (@category.Status == "Rejected")
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </div>

                        <div class="category-stats">
                            <span class="badge bg-light text-dark">
                                <i class="bi bi-journal-text me-1"></i>@category.RecipeCount recipes
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-tags display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No categories available yet</h4>
            <p class="text-muted">Categories will appear here once they're created and approved.</p>
        </div>
    }
</div>