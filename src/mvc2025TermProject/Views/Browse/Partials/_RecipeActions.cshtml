@model mvc2025TermProject.Models.RecipeDetailsViewModel

<div class="d-flex flex-wrap gap-3 justify-content-center">
    <button type="button" class="btn btn-outline-cb-primary" data-bs-toggle="modal" data-bs-target="#shareRecipeModal">
        <i class="bi bi-share me-1"></i> Share Recipe
    </button>

    <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#reportRecipeModal">
        <i class="bi bi-flag me-1"></i> Report Recipe
    </button>

    <a asp-controller="Browse" asp-action="Print" asp-route-id="@Model.ID"
       class="btn btn-outline-secondary" target="_blank">
        <i class="bi bi-printer me-1"></i> Print Recipe
    </a>
</div>