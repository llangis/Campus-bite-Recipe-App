@using Microsoft.AspNetCore.Identity
@using mvc2025TermProject.Data

@inject SignInManager<CampusBitesUser> SignInManager
@inject UserManager<CampusBitesUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user != null ? $"{user.FirstName} {user.LastName}" : User.Identity?.Name;
}

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link rounded text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @displayName!</a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link rounded btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link rounded text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link rounded text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>