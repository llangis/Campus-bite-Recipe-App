@model mvc2025TermProject.Models.IngredientFormFieldsViewModel

<div class="mb-3">
    <label asp-for="Name" class="form-label fw-semibold">Ingredient Name</label>
    <input asp-for="Name" class="form-control" placeholder="e.g., Green Onion, Whole Milk" />
    <span asp-validation-for="Name" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="Type" class="form-label fw-semibold">Ingredient Type</label>
    <input asp-for="Type" class="form-control" placeholder="e.g., Dairy, Produce, Spice" />
    <span asp-validation-for="Type" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label fw-semibold">Description</label>
    <textarea asp-for="Description" class="form-control" rows="3"
              placeholder="Optional: a short description (10–500 chars)."></textarea>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>