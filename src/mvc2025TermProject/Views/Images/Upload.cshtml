@model mvc2025TermProject.Models.ImageUploadViewModel

@{
    ViewData["Title"] = "Upload Recipe Images";
}

<div class="container my-3 my-md-4">
    <div class="position-relative">
        <div class="auth-accent rounded-top"></div>

        <div class="bg-white border shadow-sm overflow-hidden">

            <div class="p-3 p-md-4 border-bottom">
                <!-- Desktop: Title left, Date right -->
                <div class="d-none d-md-flex align-items-center justify-content-between mb-1">
                    <h3 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h3>

                    <div class="text-muted fw-medium">
                        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd, MMMM d, yyyy")
                    </div>
                </div>

                <!-- Mobile: Just Title -->
                <div class="d-md-none">
                    <h3 class="fw-bold text-dark mb-1">@ViewData["Title"]</h3>
                </div>
            </div>

            <div class="p-3 p-md-4">
                <form method="get" asp-action="Upload">
                    <div class="mb-3">
                        <label for="id" class="form-label fw-semibold">Select Recipe</label>
                        <select name="id" class="form-select" asp-items="ViewBag.RecipeId" onchange="this.form.submit()">
                            <option value="">-- Choose a Recipe --</option>
                        </select>
                    </div>
                </form>
            </div>

            <div class="px-3 px-md-4 pb-3 pb-md-4">
                <!-- Image Gallery (only show if recipe selected) -->
                @if (Model != null && Model.RecipeId.HasValue)
                {
                    <partial name="Partials/_ImageGallery" model="Model" />
                    <partial name="Partials/_UploadImageModal" model="Model" />
                }
                else
                {
                    <!-- No Recipe Selected Message -->
                    <div class="text-center py-5">
                        <i class="bi bi-images display-1 text-muted"></i>
                        <h4 class="text-muted mt-3">Select a recipe to manage images</h4>
                        <p class="text-muted">Choose a recipe from the dropdown above to view and manage its images.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>