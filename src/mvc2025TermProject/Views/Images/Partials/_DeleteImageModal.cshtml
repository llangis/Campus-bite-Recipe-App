@model mvc2025TermProject.Models.Image

@{
    var modalId = $"deleteImageModal-{Model.Id}";
}

<div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">

            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold text-dark">Delete Image</h5>
                @* <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button> *@
            </div>

            <div class="modal-body">
                @if (Model.IsMainImage == true)
                {
                    <div class="alert alert-warning py-2 mb-2 small" role="alert">
                        <i class="bi bi-star-fill me-1"></i>
                        <strong>This is your main image!</strong>
                    </div>
                }

                <p class="mb-3">
                    Are you sure you want to delete this image from the recipe?
                </p>

                <div class="p-3 border rounded bg-light mb-3 text-center">
                    <img src="@Model.FilePath"
                         class="img-fluid rounded"
                         alt="@Model.AltText"
                         style="max-height: 150px; object-fit: cover; opacity: @(Model.IsApproved == true ? "1" : "0.6");" />

                    @if (!string.IsNullOrEmpty(Model.AltText))
                    {
                        <div class="mt-2">
                            <span class="text-muted small">"@Model.AltText"</span>
                        </div>
                    }
                </div>

                @if (Model.IsMainImage == true)
                {
                    <div class="alert alert-info py-2 mb-2 small" role="alert">
                        <i class="bi bi-info-circle me-1"></i>
                        Deleting the main image will remove it from the primary display.
                    </div>
                }

                @if (Model.IsApproved == false)
                {
                    <div class="alert alert-secondary py-2 mb-2 small" role="alert">
                        <i class="bi bi-clock me-1"></i>
                        This image is still pending admin approval.
                    </div>
                }

                <div class="alert alert-warning small py-2 mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <strong>Note:</strong> This action cannot be undone.
                </div>
            </div>

            <div class="modal-footer border-0 px-4 pb-4 pt-2">
                <a asp-action="Upload" asp-route-id="@Model.RecipeId" class="btn btn-light border shadow-sm">
                    <i class="bi bi-x-circle me-1"></i> Cancel
                </a>

                <form asp-controller="Images" asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger shadow-sm">
                        <i class="bi bi-trash me-1"></i> Delete Image
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>