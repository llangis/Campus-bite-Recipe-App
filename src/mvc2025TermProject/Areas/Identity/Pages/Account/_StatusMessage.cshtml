@model string

@if (!string.IsNullOrWhiteSpace(Model))
{
    var isError = Model.StartsWith("Error");
    var alertClass = isError ? "danger" : "success";
    // Use *-emphasis so the icon stays readable on colored backgrounds (BS 5.3+)
    var iconClass = isError
        ? "bi-exclamation-triangle-fill text-danger"
        : "bi-check-circle-fill text-success-emphasis";

    <div class="alert alert-@alertClass alert-dismissible alert-dismissible" role="alert">
        <i class="@iconClass me-2"></i>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        @Model
    </div>
}

