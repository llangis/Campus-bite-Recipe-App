@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}


<div class="container text-center my-5">
    <section class="my-3 my-md-4">
        <h2 class="fs-2 py-3 mb-3 fw-bold text-dark">@ViewData["Title"]</h2>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                @{
                    if (Model.DisplayConfirmAccountLink)
                    {
                        <div class="alert alert-info shadow-sm">
                            <i class="bi bi-info-circle-fill me-2 text-primary"></i>
                            This demo app does not have a real email sender configured.
                            See <a href="https://aka.ms/aspaccountconf" target="_blank" class="fw-semibold text-decoration-none">these docs</a>
                            for details on enabling a real email service.<br />
                            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="fw-semibold text-decoration-none text-primary">
                                Click here to confirm your account manually.
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success shadow-sm p-4 rounded-3 border-start border-4">
                            <i class="bi bi-envelope-check-fill me-2 text-success"></i>
                            <strong>Great news!</strong> Your Campus Bites account has been created.
                            We’ve sent a confirmation link to your email address.
                            Please check your inbox (and junk folder just in case) to verify your account.
                            Once confirmed, you’ll be ready to explore recipes and share your own student-friendly meals.
                        </div>
                    }
                }
            </div>
        </div>

        <p class="text-muted mt-4 small">
            Didn’t receive the message yet? It might take a minute or check your spam folder.
            <br />
            Still nothing?
            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none">
                Resend
            </a>
        </p>
    </section>
</div>

