@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend email confirmation";
}

<div class="container my-3 my-md-4 pb-5 h-100 d-flex align-items-center justify-content-center">
    <div class="col-md-6">
        <div class="card auth-card shadow-lg">
            <div class="auth-accent rounded-top"></div>

            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-5">
                    <h4 class="fs-4 fw-bold mb-2">@ViewData["Title"]</h4>
                    <p class="text-muted mb-4">Enter the email associated with your account and we’ll send a new confirmation link.</p>
                </div>

                <section>

                    <form method="post">
                        @*
                        <div asp-validation-summary="All" class="text-danger" role="alert"></div>
                        *@
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label"></label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-lg btn-cb-primary text-white">Resend</button>
                    </form>

                    <p class="text-muted small mt-3 mb-0">
                        If an account exists for that email, you’ll receive a new confirmation link shortly.
                        Check your spam/junk folder if you don’t see it.
                    </p>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-center gap-3 small">
                        <a asp-area="Identity" asp-page="/Account/Login" class="text-decoration-none text-color-eb">Back to log in</a>
                        <span class="text-muted">•</span>
                        <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none text-color-eb">Create a new account</a>
                    </div>

                </section>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
