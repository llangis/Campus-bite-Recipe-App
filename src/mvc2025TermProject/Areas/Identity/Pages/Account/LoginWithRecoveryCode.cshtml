@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code verification";
}

<div class="container my-3 my-md-4 pb-5 h-100 d-flex align-items-center justify-content-center">
    <div class="col-md-6">
        <div class="card auth-card shadow-lg">
            <div class="auth-accent rounded-top"></div>

            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-5">
                    <h4 class="fs-4 fw-bold mb-2">@ViewData["Title"]</h4>
                    <p class="text-muted mb-0">
                        Enter one of your recovery codes to continue. This login won’t be remembered unless
                        you later sign in with an authenticator code or disable 2FA.
                    </p>
                </div>

                <section>
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.RecoveryCode"
                                   class="form-control"
                                   autocomplete="one-time-code"
                                   inputmode="text"
                                   placeholder="ABCD-EFGH-IJKL" />
                            <label asp-for="Input.RecoveryCode" class="form-label">Recovery code</label>
                            <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-lg btn-cb-primary">Log in</button>
                    </form>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-center gap-3 small">
                        <a asp-area="Identity" asp-page="/Account/Login" class="text-decoration-none text-color-eb">Back to log in</a>
                        <span class="text-muted">•</span>
                        <a asp-page="./LoginWith2fa" class="text-decoration-none text-color-eb">Use authenticator code instead</a>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

