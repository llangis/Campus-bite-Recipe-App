@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h5 class="fw-bold mb-3">@ViewData["Title"]</h5>


<p class="mb-2 text-muted">
    Your account contains personal data that you have provided. You can download or permanently delete this data.
</p>

<div class="alert alert-warning small">
    <i class="bi bi-exclamation-triangle me-1"></i>
    <strong>Deleting this data will permanently remove your account.</strong> This action cannot be undone.
</div>

<div class="d-flex gap-2">
    <form id="download-data" asp-page="DownloadPersonalData" method="post">
        <button class="btn btn-outline-cb-primary" type="submit">
            <i class="bi bi-download me-1"></i>Download Data
        </button>
    </form>

    <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger">
        <i class="bi bi-trash3 me-1"></i>Delete Account
    </a>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

