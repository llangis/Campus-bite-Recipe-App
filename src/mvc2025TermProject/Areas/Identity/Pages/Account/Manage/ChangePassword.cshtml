@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h5 class="fw-bold mb-3">@ViewData["Title"]</h5>

<partial name="_StatusMessage" for="StatusMessage" />


<form id="change-password-form" method="post" class="mt-3" aria-describedby="pw-help">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2" role="alert" aria-live="polite"></div>

    <div class="form-floating mb-3">
        <input asp-for="Input.OldPassword"
                class="form-control"
                autocomplete="current-password"
                aria-required="true"
                placeholder="Current password" />
        <label asp-for="Input.OldPassword">Current password</label>
        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Input.NewPassword"
                class="form-control"
                autocomplete="new-password"
                aria-required="true"
                placeholder="New password" />
        <label asp-for="Input.NewPassword">New password</label>
        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Input.ConfirmPassword"
                class="form-control"
                autocomplete="new-password"
                aria-required="true"
                placeholder="Confirm new password" />
        <label asp-for="Input.ConfirmPassword">Confirm new password</label>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button type="submit" class="btn btn-cb-primary w-100 btn-lg">Update password</button>

    <p id="pw-help" class="text-muted small mt-3 mb-0">
        Use a strong password you don’t use elsewhere. After updating, you’ll sign in with your new password.
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


