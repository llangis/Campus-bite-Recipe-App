@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable two-factor authentication (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<h5 class="fw-bold mb-3">@ViewData["Title"]</h5>

<div class="alert alert-warning d-flex align-items-start" role="alert">
    <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
    <div>
        <p class="mb-2">
            <strong>This action will disable two-factor authentication (2FA) for your account.</strong>
        </p>
        <p class="mb-0">
            This does not reset your authenticator keys.
            If you want to change the key used in your authenticator app, please
            <a asp-page="./ResetAuthenticator" class="text-decoration-none text-primary fw-semibold">reset your authenticator keys</a>.
        </p>
    </div>
</div>

<form method="post" class="mt-3">
    <div class="d-grid d-sm-flex gap-2">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-shield-x me-1"></i> Disable 2FA
        </button>
        <a asp-page="./TwoFactorAuthentication" class="btn btn-outline-cb-primary">Cancel</a>
    </div>
</form>

