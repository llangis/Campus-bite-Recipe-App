@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h5 class="fw-bold mb-3">@ViewData["Title"]</h5>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post" class="mt-3" aria-describedby="profile-help">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2" role="alert" aria-live="polite"></div>

    <div class="form-floating mb-3">
        <input asp-for="Username"
               class="form-control bg-light"
               placeholder="Username"
               disabled
               autocomplete="username" />
        <label asp-for="Username">Username</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Input.PhoneNumber"
               class="form-control"
               placeholder="Enter phone number"
               autocomplete="tel"
               inputmode="tel" />
        <label asp-for="Input.PhoneNumber">Phone number</label>
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
    </div>

    <div class="d-grid d-sm-flex gap-2">
        <button id="update-profile-button" type="submit" class="btn btn-cb-primary text-white">
            Save
        </button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
    </div>

    <p id="profile-help" class="text-muted small mt-3 mb-0">
        Your username is set by the system. Phone numbers are used for account recovery and security notifications.
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

